{
  "name": "@sudobility/heavymath_ui",
  "version": "0.0.1",
  "description": "Shared UI components, hooks, and utilities for Heavymath prediction market apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "verify": "bun run typecheck && bun run lint && bun run format:check"
  },
  "peerDependencies": {
    "@sudobility/components": ">=5.0.0",
    "@sudobility/design": ">=1.0.0",
    "@sudobility/di": ">=1.5.0",
    "@sudobility/heavymath_contracts": ">=0.1.0",
    "@sudobility/heavymath_indexer_client": ">=0.0.45",
    "@sudobility/heavymath_lib": ">=0.0.72",
    "@sudobility/heavymath_types": ">=0.0.26",
    "@sudobility/types": ">=1.9.0",
    "@sudobility/web3-components": ">=2.0.0",
    "@heroicons/react": ">=2.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "i18next": ">=25.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-i18next": ">=16.0.0",
    "react-icons": ">=5.0.0",
    "react-router-dom": ">=7.0.0",
    "recharts": ">=3.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@sudobility/components": "^5.0.63",
    "@sudobility/design": "^1.1.30",
    "@sudobility/di": "^1.5.53",
    "@sudobility/heavymath_contracts": "^0.1.60",
    "@sudobility/heavymath_indexer_client": "^0.0.45",
    "@sudobility/heavymath_lib": "^0.0.72",
    "@sudobility/heavymath_types": "^0.0.26",
    "@sudobility/types": "^1.9.61",
    "@sudobility/web3-components": "^2.0.13",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.90.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "i18next": "^25.8.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "typescript": "~5.9.3",
    "viem": "^2.38.0",
    "wagmi": "^2.19.0"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudobility-usf/heavymath_ui.git"
  }
}

{
  "name": "@sudobility/heavymath_ui",
  "version": "0.0.24",
  "description": "Shared UI components, hooks, and utilities for Heavymath prediction market apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run typecheck && bun run lint && bun run test && bun run format:check"
  },
  "peerDependencies": {
    "@sudobility/components": "^5.0.71",
    "@sudobility/design": "^1.1.30",
    "@sudobility/di": "^1.5.56",
    "@sudobility/heavymath_contracts": "^0.1.72",
    "@sudobility/heavymath_indexer_client": "^0.0.58",
    "@sudobility/heavymath_lib": "^0.0.86",
    "@sudobility/heavymath_types": "^0.0.33",
    "@sudobility/types": "^1.9.62",
    "@sudobility/web3-components": "^2.0.15",
    "@heroicons/react": ">=2.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "i18next": ">=25.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-i18next": ">=16.0.0",
    "react-icons": ">=5.0.0",
    "react-router-dom": ">=7.0.0",
    "recharts": ">=3.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@sudobility/components": "^5.0.71",
    "@sudobility/design": "^1.1.30",
    "@sudobility/di": "^1.5.56",
    "@sudobility/heavymath_contracts": "^0.1.72",
    "@sudobility/heavymath_indexer_client": "^0.0.58",
    "@sudobility/heavymath_lib": "^0.0.86",
    "@sudobility/heavymath_types": "^0.0.33",
    "@sudobility/types": "^1.9.62",
    "@sudobility/web3-components": "^2.0.15",
    "@tanstack/react-query": "^5.90.5",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "i18next": "^25.8.7",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "typescript": "~5.9.3",
    "viem": "^2.38.0",
    "vitest": "^4.1.5",
    "wagmi": "^2.19.0"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudobility-usf/heavymath_ui.git"
  },
  "dependencies": {
    "dompurify": "^3.4.7",
    "marked": "^18.0.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0"
  }
}
